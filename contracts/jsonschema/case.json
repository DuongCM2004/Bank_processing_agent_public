{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ops-agent.bank.local/schemas/case.json",
  "title": "Case",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "workflow_type", "priority", "status", "review_required", "assigned_queue", "created_at_utc", "updated_at_utc"],
  "properties": {
    "case_id": { "type": "string" },
    "workflow_type": { "type": "string" },
    "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] },
    "status": { "type": "string", "enum": ["received", "stored", "queued", "processing", "validated", "review_required", "in_review", "corrected", "approved", "rejected", "escalated", "failed", "closed"] },
    "review_required": { "type": "boolean" },
    "assigned_queue": { "type": "string" },
    "customer_reference": { "type": ["string", "null"] },
    "compliance_status": { "type": ["string", "null"] },
    "final_outcome": { "type": ["string", "null"] },
    "document_ids": { "type": "array", "items": { "type": "string" } },
    "review_task_ids": { "type": "array", "items": { "type": "string" } },
    "current_workflow_run_id": { "type": ["string", "null"] },
    "version_refs": {
      "$ref": "version-refs.json"
    },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "updated_at_utc": { "type": "string", "format": "date-time" }
  }
}
