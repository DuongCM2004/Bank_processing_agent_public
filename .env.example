OPS_AGENT_OBJECT_STORE_BUCKET=ops-agent-artifacts
OPS_AGENT_OBJECT_STORE_ENDPOINT=http://localhost:9000
OPS_AGENT_OBJECT_STORE_REGION=us-east-1
OPS_AGENT_OBJECT_STORE_ACCESS_KEY_ID=
OPS_AGENT_OBJECT_STORE_SECRET_ACCESS_KEY=
OPS_AGENT_TEMPORAL_NAMESPACE=ops-agent
OPS_AGENT_TEMPORAL_HOST=localhost:7233
OPS_AGENT_KEYCLOAK_ISSUER_URL=http://localhost:8080/realms/ops-agent
OPS_AGENT_OIDC_AUDIENCE=ops-agent-api
OPS_AGENT_JWKS_CACHE_TTL_SECONDS=900
OPS_AGENT_AUDIT_LOG_LEVEL=INFO
OPS_AGENT_REVIEW_QUEUE_DEFAULT=ops_review
OPS_AGENT_PROMPT_REGISTRY_VERSION=2026-04-14
OPS_AGENT_RULE_PACK_VERSION=2026-04-14
OPS_AGENT_MODEL_RELEASE_VERSION=2026-04-14
OPS_AGENT_ENABLE_PROMPT_RUNTIME=true
OPS_AGENT_MAX_UPLOAD_BYTES=25000000
OPS_AGENT_ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg
