# Public frontend runtime config. Never put secrets in VITE_* variables.
VITE_OPS_AGENT_APP_NAME=Ops Agent
VITE_OPS_AGENT_ENV=local
VITE_OPS_AGENT_API_BASE_URL=/api/v1
VITE_OPS_AGENT_API_PROXY_TARGET=http://localhost:8003
VITE_OPS_AGENT_ENABLE_MOCK_API=false
VITE_OPS_AGENT_API_TIMEOUT_MS=8000
VITE_OPS_AGENT_DEV_USER_ID=local-admin
VITE_OPS_AGENT_DEV_ROLES=admin
VITE_OPS_AGENT_DEV_DISPLAY_NAME=Local Admin
