{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ops-agent.bank.local/schemas/document-metadata.json",
  "title": "DocumentMetadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_id", "case_id", "filename", "mime_type", "source_channel", "retention_class", "status", "created_at_utc"],
  "properties": {
    "document_id": { "type": "string" },
    "case_id": { "type": "string" },
    "filename": { "type": "string" },
    "mime_type": { "type": "string" },
    "source_channel": { "type": "string" },
    "retention_class": { "type": "string" },
    "status": { "type": "string", "enum": ["not_started", "in_progress", "complete", "failed"] },
    "document_role": { "type": ["string", "null"] },
    "document_version_id": { "type": ["string", "null"] },
    "file_hash": { "type": ["string", "null"] },
    "raw_object_key": { "type": ["string", "null"] },
    "page_count": { "type": ["integer", "null"] },
    "quarantine_status": { "type": ["string", "null"] },
    "version_refs": {
      "$ref": "version-refs.json"
    },
    "created_at_utc": { "type": "string", "format": "date-time" }
  }
}
