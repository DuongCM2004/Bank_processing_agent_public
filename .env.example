# Monorepo local defaults. Copy service-specific values into app-level .env files
# or source this file from local tooling. Do not use these values in staging or production.

# Shared runtime.
OPS_AGENT_ENV=local
OPS_AGENT_APP_NAME=Ops Agent Backend
OPS_AGENT_DEBUG=true

# Backend API.
OPS_AGENT_API_V1_PREFIX=/api/v1
OPS_AGENT_CORS_ORIGINS=http://localhost:5173
OPS_AGENT_LOG_LEVEL=INFO
OPS_AGENT_LOG_JSON=false

# PostgreSQL.
OPS_AGENT_POSTGRES_DSN=postgresql+psycopg://ops_agent:ops_agent@localhost:5432/ops_agent
OPS_AGENT_DB_ECHO=false
OPS_AGENT_DB_POOL_SIZE=10
OPS_AGENT_DB_MAX_OVERFLOW=20
OPS_AGENT_DB_POOL_PRE_PING=true
OPS_AGENT_ENABLE_DB_HEALTHCHECK=true

# Redis / queue.
OPS_AGENT_REDIS_URL=redis://localhost:6379/0
OPS_AGENT_TASK_QUEUE_NAME=ops-agent-default

# Storage.
OPS_AGENT_STORAGE_BACKEND=local
OPS_AGENT_STORAGE_ROOT_PATH=./.runtime/uploads
OPS_AGENT_STORAGE_BLOB_ENDPOINT=
OPS_AGENT_STORAGE_BLOB_BUCKET=
OPS_AGENT_STORAGE_KMS_KEY_ID=
OPS_AGENT_MAX_UPLOAD_BYTES=15728640
OPS_AGENT_ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg

# AI provider integration. Use gpt for notebook-style OpenAI Responses API extraction.
OPS_AGENT_AI_PROVIDER_MODE=gpt
OPS_AGENT_AI_PROVIDER_ENDPOINT=
OPS_AGENT_AI_PROVIDER_TIMEOUT_SECONDS=30
OPS_AGENT_OPENAI_API_KEY=
OPS_AGENT_GPT_MODEL=gpt-4.1
OPS_AGENT_OPENAI_STORE_RESPONSE=false
OPS_AGENT_LLM_PROMPT_VERSION=identity-document-extraction-v1
OPS_AGENT_LLM_SCHEMA_VERSION=identity-document-v1
OPS_AGENT_IMAGE_MAX_DIMENSION_PX=1600
OPS_AGENT_IMAGE_JPEG_QUALITY=90

# Processing policy.
OPS_AGENT_PROCESSING_MAX_RETRY_ATTEMPTS=3
OPS_AGENT_PROCESSING_MIN_OCR_CONFIDENCE=0.75
OPS_AGENT_PROCESSING_MIN_EXTRACTION_CONFIDENCE=0.8

# Frontend public runtime config. VITE_* values are visible in browser bundles.
VITE_OPS_AGENT_APP_NAME=Ops Agent
VITE_OPS_AGENT_ENV=local
VITE_OPS_AGENT_API_BASE_URL=/api/v1
VITE_OPS_AGENT_API_PROXY_TARGET=http://localhost:8003
VITE_OPS_AGENT_ENABLE_MOCK_API=false
